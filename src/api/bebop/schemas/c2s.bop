// client_to_server.bop — p2pcv signaling protocol, client → server messages

union C2sMsg {
    1 -> struct RegisterPeer {
        string AuthToken;
    }
    2 -> struct GetFriendPeerId {
        guid FriendUserId;
    }
    3 -> struct NewGame {
        guid ReceiverUserId;
        guid VariantId;
        string VariantVersion;
    }
    4 -> struct NewGameAnswer {
        bool Accepted;
    }
}
